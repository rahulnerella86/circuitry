    {
      "id": "nlm_iir_filter_fpga",
      "name": "IIR Low-Pass Filter (FPGA)",
      "category": "fpga",
      "tags": ["dsp", "filter", "iir", "low pass", "fpga", "verilog", "vhdl", "high performance", "low latency", "digital signal processing", "rtl", "hdl", "hardware", "logic"],
      "description": "A digital Infinite Impulse Response (IIR) low-pass filter optimized for FPGA deployment using DSP slices.",
      "parameters": {
        "clock_freq": 100000000,
        "data_width": 16,
        "latency_cycles": 3
      },
      "architecture": {
        "components": [
          {"id": "fpga_mult", "type": "dsp_slice", "value": "18x18", "purpose": "Coefficient multiplication"},
          {"id": "fpga_add", "type": "adder", "value": "32-bit", "purpose": "Accumulation"},
          {"id": "fpga_reg", "type": "register", "value": "16-bit", "purpose": "Delay elements"}
        ],
        "connections": [
          {"from": "fpga_mult.out", "to": "fpga_add.in"},
          {"from": "fpga_add.out", "to": "fpga_reg.in"}
        ],
        "hdl": "module iir_filter (\n  input  wire        clk,\n  input  wire        rst,\n  input  wire signed [15:0] din,\n  output reg  signed [15:0] dout\n);\n  // IIR Direct Form II implementation\n  // Coefficients: b0=0.0675, b1=0.135, b2=0.0675, a1=-1.1430, a2=0.4128\n  parameter signed [17:0] B0 = 18'sd443;\n  parameter signed [17:0] B1 = 18'sd886;\n  parameter signed [17:0] A1 = -18'sd7498;\n  parameter signed [17:0] A2 = 18'sd2710;\n  reg signed [31:0] w0, w1, w2;\n  always @(posedge clk) begin\n    if (rst) begin w0<=0; w1<=0; w2<=0; dout<=0; end\n    else begin\n      w0 <= din - (A1*w1>>>13) - (A2*w2>>>13);\n      dout <= (B0*w0 + B1*w1 + B0*w2) >>> 13;\n      w2 <= w1; w1 <= w0;\n    end\n  end\nendmodule"
      },
      "performance": {
        "latency": "30 ns",
        "power": "Depends on FPGA fabric",
        "hardware_efficiency": "High utilization of DSP blocks"
      },
      "tradeoffs": "IIR provides steeper roll-off with fewer taps vs FIR, saving area, but can have non-linear phase response and stability issues."
    },
